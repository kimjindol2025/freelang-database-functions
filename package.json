      "lines": 290,
      "description": "High-performance queries with Query Planner and Iterator pattern",
      "philosophy": "카르마의 길 (Follow the optimal path)",
      "functions": 14,
      "key_features": [
        "Query parsing and planning",
        "Index selection",
        "Row estimation",
        "Iterator-based streaming (48B/row)",
        "Aggregation (COUNT, SUM, AVG)",
        "LIMIT/OFFSET support"
      ]
    },
    "db_exec": {
      "file": "src/db_exec.free",
      "lines": 270,
      "description": "State changes (INSERT/UPDATE/DELETE) with WAL and ACID compliance",
      "philosophy": "원자적 변경 (Atomic, consistent, isolated, durable)",
      "functions": 12,
      "key_features": [
        "Write-Ahead Logging (WAL)",
        "ACID compliance verification",
        "Bulk operations",
        "Failure recovery",
        "Audit trail generation"
      ]
    },
    "db_transaction": {
      "file": "src/db_transaction.free",
      "lines": 320,
      "description": "Atomic transaction management with 2-phase commit protocol",
      "philosophy": "전부가 아니면 전무 (All or nothing)",
      "functions": 15,
      "key_features": [
        "2-Phase Commit (2PC) protocol",
        "Savepoints for partial rollback",
        "Distributed transactions",
        "Isolation level enforcement",
        "Deadlock detection"
      ]
    },
    "db_index": {
      "file": "src/db_index.free",
      "lines": 310,
      "description": "B-Tree and Hash index creation and optimization",
      "philosophy": "시간이 흐를수록 더 빨라지는 데이터베이스 (Database gets faster over time)",
      "functions": 13,
      "key_features": [
        "B-Tree indexes (range queries)",
        "Hash indexes (equality queries)",
        "Composite indexes",
        "Index recommendations",
        "Index statistics and monitoring",
        "Rebuild and defragment operations"
      ]
    },
    "db_backup": {
      "file": "src/db_backup.free",
      "lines": 380,
      "description": "Full/incremental/differential backups with point-in-time recovery",
      "philosophy": "기록이 증명이다 (The record is the proof)",
      "functions": 16,
      "key_features": [
        "Full backup strategy",
        "Incremental backups",
        "Differential backups",
        "Point-in-Time Recovery (PITR)",
        "Compression (40-70% ratio)",
        "Backup verification and integrity checks",
        "Retention policy enforcement"
      ]
    }
